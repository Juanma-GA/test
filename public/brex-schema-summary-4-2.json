{
  "standard": "S1000D Issue 4.2",
  "rootElement": "dmodule",
  "infoCode": "022",
  "namespaces": {
    "xlink": "http://www.w3.org/1999/xlink",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "xsi": "http://www.w3.org/2001/XMLSchema-instance",
    "dc": "http://www.purl.org/dc/elements/1.1/"
  },
  "dmodule_opening_tag": "<dmodule xsi:noNamespaceSchemaLocation=\"http://www.s1000d.org/S1000D_4-2/xml_schema_flat/brex.xsd\" xmlns:dc=\"http://www.purl.org/dc/elements/1.1/\" xmlns:rdf=\"http://www.w3.org/1999/02/22-rdf-syntax-ns#\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\">",
  "structure": {
    "dmodule": {
      "children_required": ["identAndStatusSection", "content"],
      "note": "Use exact namespace declarations from dmodule_opening_tag above"
    },
    "identAndStatusSection": {
      "children_required": ["dmAddress", "dmStatus"]
    },
    "dmAddress": {
      "children_required": ["dmIdent", "dmAddressItems"]
    },
    "dmIdent": {
      "children_required": ["dmCode", "language", "issueInfo"]
    },
    "dmCode": {
      "attributes_required": [
        "modelIdentCode", "systemDiffCode", "systemCode",
        "subSystemCode", "subSubSystemCode", "assyCode",
        "disassyCode", "disassyCodeVariant", "infoCode",
        "infoCodeVariant", "itemLocationCode"
      ],
      "fixed_values": {
        "infoCode": "022",
        "infoCodeVariant": "A",
        "itemLocationCode": "A",
        "systemCode": "00",
        "subSystemCode": "0",
        "subSubSystemCode": "0",
        "assyCode": "00",
        "disassyCode": "00",
        "disassyCodeVariant": "A"
      }
    },
    "language": {
      "attributes_required": ["languageIsoCode", "countryIsoCode"]
    },
    "issueInfo": {
      "attributes_required": ["issueNumber", "inWork"]
    },
    "dmAddressItems": {
      "children_required": ["issueDate", "dmTitle"]
    },
    "issueDate": {
      "attributes_required": ["year", "month", "day"],
      "note": "Format: year=YYYY month=MM day=DD"
    },
    "dmTitle": {
      "children_required": ["techName"],
      "children_optional": ["infoName"]
    },
    "dmStatus": {
      "children_required": [
        "security",
        "responsiblePartnerCompany",
        "originator",
        "applic",
        "brexDmRef",
        "qualityAssurance"
      ],
      "attributes_optional": ["issueType"]
    },
    "security": {
      "attributes_required": ["securityClassification"],
      "valid_values": {
        "securityClassification": ["01","02","03","04","05","06","07","08","09","10"]
      }
    },
    "responsiblePartnerCompany": {
      "attributes_optional": ["enterpriseCode"],
      "children_optional": ["enterpriseName"]
    },
    "originator": {
      "attributes_optional": ["enterpriseCode"],
      "children_optional": ["enterpriseName"]
    },
    "applic": {
      "note": "Always use: <applic><displayText><simplePara>All</simplePara></displayText></applic>"
    },
    "brexDmRef": {
      "note": "SELF-REFERENCE — identical dmCode values as the document itself",
      "structure": "<brexDmRef><dmRef><dmRefIdent><dmCode [same attributes as dmIdent/dmCode]/><issueInfo issueNumber=\"001\" inWork=\"00\"/></dmRefIdent></dmRef></brexDmRef>"
    },
    "qualityAssurance": {
      "note": "Use <qualityAssurance><unverified/></qualityAssurance> for new documents"
    },
    "content": {
      "children_required": ["brex"]
    },
    "brex": {
      "children_optional": ["commonInfo", "contextRules", "nonContextRules"],
      "note": "brex contains contextRules directly — there is NO brexDoc and NO brexDmRules"
    },
    "contextRules": {
      "attributes_optional": ["rulesContext"],
      "children_optional": ["structureObjectRuleGroup"],
      "note": "rulesContext = empty string for rules applying to all DM types"
    },
    "structureObjectRuleGroup": {
      "children_required": ["structureObjectRule"],
      "note": "One structureObjectRule per BRDP"
    },
    "structureObjectRule": {
      "children_required": ["objectPath"],
      "children_optional": ["brDecisionRef", "objectUse", "objectValue"],
      "order": ["brDecisionRef", "objectPath", "objectUse", "objectValue"]
    },
    "brDecisionRef": {
      "note": "ATTRIBUTE-BASED — use brDecisionIdentNumber attribute, NOT text content",
      "example": "<brDecisionRef brDecisionIdentNumber=\"BRDP-S1-00001\"/>"
    },
    "objectPath": {
      "note": "XPath-like path to the S1000D element this rule applies to",
      "attributes": {
        "allowedObjectFlag": {
          "values": ["0", "1", "2"],
          "meaning": {
            "0": "prohibited — element must NOT be used",
            "1": "mandatory — element MUST be used",
            "2": "optional — element may be used (default)"
          },
          "inference_rules": {
            "use_0": "proposal contains: must not, prohibited, forbidden, not allowed, discard",
            "use_1": "proposal contains: must, mandatory, required, shall, obligatory",
            "use_2": "all other cases"
          }
        }
      }
    },
    "objectUse": {
      "note": "Free text. One clear sentence summarising the BRDP decision."
    },
    "nonContextRules": {
      "children_required": ["nonContextRule"]
    },
    "nonContextRule": {
      "children_required": ["simplePara"],
      "children_optional": ["brDecisionRef"],
      "note": "Use for general rules not tied to a specific element path"
    }
  },
